model restaurants {
  id          String   @id @default(uuid())
  ownerId     String @unique
  name        String
  coverImg    String
  description String
  openingTime String
  closingTime String
  offday      String
  rating      Float? @default(0)
  banned      Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  meals       meals[]
  user  User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}


model meals {
  id            String     @id @default(uuid())
  restaurantsId String
  name          String
  coverImg      String
  description   String
  price         Float
  rating        Float
  catagory      catagory[]
  available     Boolean
  ingredients   String[]
  allergens     String[]
  calories      Int
  servingSize   String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  orders orders[]

  restaurant restaurants @relation(fields: [restaurantsId], references: [id], onDelete: Cascade)
  

}
